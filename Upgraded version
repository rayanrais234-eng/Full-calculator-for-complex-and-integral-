double findPi(string s) {
    s.erase(remove_if(s.begin(), s.end(), ::isspace), s.end());
    if (s.find("pi") == string::npos) 
        return stod(s);
      
    size_t slash = s.find("/");
    if (slash != string::npos) {
        double denominator = findPi(s.substr(slash + 1));
        double numerator = findPi(s.substr(0, slash));
        return numerator / denominator;
    }
    
    size_t mul = s.find("pi");
    double coeff = 1.0;
    if (mul != string::npos) {
        coeff = stod(s.substr(0, mul));
        return coeff * PI;
    }
}

